{
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": [
                    "{$ENV|value-of:XDG_BIN_HOME}codecept",
                    "run",
                    "--config {$ENV|value-of:\\Bartlett\\CaptainHookBinPlugin\\BinPlugin.config-file|cache:false}",
                    "{$ENV|value-of:\\Bartlett\\CaptainHookBinPlugin\\BinPlugin.colors-flag|cache:false}"
                ],
                "config": {
                    "label": "Unit Tests (with Codeception)"
                },
                "options": {
                    "colors": "ansi",
                    "config-file": "{$ENV|value-of:XDG_CONFIG_HOME}/codeception.yml",
                    "package-require": [
                        "codeception/codeception",
                        "^5"
                    ]
                }
            }
        ]
    }
}
